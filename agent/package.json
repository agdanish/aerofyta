{
  "name": "@xzashr/aerofyta",
  "version": "1.1.0",
  "description": "Autonomous multi-chain payment agent powered by Tether WDK — ReAct reasoning, multi-agent consensus, Wallet-as-Brain",
  "author": "Danish <agdanishr@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/xzashr/aerofyta"
  },
  "homepage": "https://github.com/xzashr/aerofyta#readme",
  "bugs": {
    "url": "https://github.com/xzashr/aerofyta/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "tether",
    "wdk",
    "autonomous-agent",
    "crypto",
    "tipping",
    "escrow",
    "defi",
    "multi-chain",
    "ai-agent",
    "react-loop",
    "wallet"
  ],
  "type": "module",
  "main": "dist/sdk/index.js",
  "types": "dist/sdk/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./create": {
      "types": "./dist/sdk/create-agent.d.ts",
      "import": "./dist/sdk/create-agent.js"
    },
    "./middleware": {
      "types": "./dist/sdk/middleware.d.ts",
      "import": "./dist/sdk/middleware.js"
    },
    "./client": {
      "types": "./dist/sdk/client.d.ts",
      "import": "./dist/sdk/client.js"
    },
    "./services/*": "./dist/services/*.js",
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "bin": {
    "aerofyta": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "contracts/",
    "src/sdk/README.md"
  ],
  "scripts": {
    "prepublishOnly": "npm run build && npm test",
    "prepack": "npm run build",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --import tsx --test --test-force-exit src/__tests__/*.test.ts src/__tests__/e2e/*.test.ts src/__tests__/unit/*.test.ts src/__tests__/integration/*.test.ts",
    "test:e2e": "node --import tsx --test --test-force-exit src/__tests__/e2e-testnet.test.ts src/__tests__/e2e/*.test.ts",
    "test:unit": "node --import tsx --test --test-force-exit src/__tests__/unit/*.test.ts",
    "test:coverage": "tsc && node --experimental-test-coverage --test --test-force-exit dist/__tests__/*.test.js 2>&1 | tee coverage/coverage-output.txt",
    "lint": "eslint src/ --ext .ts",
    "deploy:contracts": "npx tsx scripts/deploy-simple.ts",
    "deploy": "npx tsx scripts/deploy-simple.ts",
    "capture-proof": "npx tsx scripts/capture-proof.ts"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@tetherto/wdk": "^1.0.0-beta.6",
    "@tetherto/wdk-mcp-toolkit": "github:tetherto/wdk-mcp-toolkit",
    "@tetherto/wdk-protocol-bridge-usdt0-evm": "^1.0.0-beta.3",
    "@tetherto/wdk-protocol-lending-aave-evm": "^1.0.0-beta.3",
    "@tetherto/wdk-protocol-swap-velora-evm": "^1.0.0-beta.4",
    "@tetherto/wdk-wallet-btc": "^1.0.0-beta.6",
    "@tetherto/wdk-wallet-evm": "^1.0.0-beta.8",
    "@tetherto/wdk-wallet-evm-erc-4337": "^1.0.0-beta.5",
    "@tetherto/wdk-wallet-solana": "^1.0.0-beta.5",
    "@tetherto/wdk-wallet-ton": "^1.0.0-beta.7",
    "@tetherto/wdk-wallet-ton-gasless": "^1.0.0-beta.4",
    "@tetherto/wdk-wallet-tron": "^1.0.0-beta.4",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ethers": "^6.14.3",
    "express": "^5.2.1",
    "grammy": "^1.41.1",
    "helmet": "^8.1.0",
    "ollama": "^0.6.3",
    "socket.io": "^4.7.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.7.0",
    "pg": "^8.16.0",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.15.4",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/uuid": "^10.0.0",
    "c8": "^11.0.0",
    "eslint": "^10.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
